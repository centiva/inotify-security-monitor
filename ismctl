#!/usr/bin/env bash

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VERSION_FILE="$PROJECT_ROOT/VERSION"
SERVICE_NAME="inotify-security-monitor"

show_version() {

    if [ -f "$VERSION_FILE" ]; then
        echo "Inotify Security Monitor"
        echo "Version: $(cat "$VERSION_FILE")"
    else
        echo "Version: unknown"
    fi

}


show_status() {

    show_version

    echo
    echo "Service:"

    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo "  Status: RUNNING"
    else
        echo "  Status: STOPPED"
    fi


    PID=$(systemctl show "$SERVICE_NAME" \
        --property MainPID \
        --value)

    if [ "$PID" != "0" ]; then
        echo "  PID: $PID"
    fi


    echo
    echo "Monitoring directories:"

    CONFIG_FILE="$PROJECT_ROOT/config/inotify-security-monitor.conf"

    if [ -f "$CONFIG_FILE" ]; then

        awk '
        /^WATCH_DIRS=/ {flag=1; next}
        /^\)/ {flag=0}
        flag && /"/ {
            gsub(/"/,"")
            print "  "$1
        }
        ' "$CONFIG_FILE"

    else

        echo "  Configuration file missing."

    fi


    echo
    echo "Logs:"
    echo "  $PROJECT_ROOT/logs/inotify-security-monitor.log"

}



check_config() {

    echo
    echo "Configuration Check"
    echo

    CONFIG_FILE="$PROJECT_ROOT/config/inotify-security-monitor.conf"


    if [ ! -f "$CONFIG_FILE" ]; then
        echo "✗ Configuration file missing"
        exit 1
    fi

    echo "✓ Configuration file found"


    export CONFIG_FILE

    if source "$PROJECT_ROOT/scripts/common.sh"; then

        echo "✓ Configuration loaded"

    else

        echo "✗ Configuration error"
        exit 1

    fi


    echo
    echo "Monitored directories:"

    awk '
    /^WATCH_DIRS=/ {flag=1; next}
    /^\)/ {flag=0}
    flag && /"/ {
        gsub(/"/,"")
        print "  "$1
    }
    ' "$CONFIG_FILE"


    echo
    echo "Exclude directories:"

    awk '
    /^EXCLUDE_DIRS=/ {flag=1; next}
    /^\)/ {flag=0}
    flag && /"/ {
        gsub(/"/,"")
        print "  "$1
    }
    ' "$CONFIG_FILE"


    echo
    echo "Exclude patterns:"

    awk '
    /^EXCLUDE_DIR_PATTERNS=/ {flag=1; next}
    /^\)/ {flag=0}
    flag && /"/ {
        gsub(/"/,"")
        print "  "$1
    }
    ' "$CONFIG_FILE"


    echo
    echo "Status: OK"

}


test_filter() {

    echo "Running filter tests..."
    echo

    "$PROJECT_ROOT/tests/filter-test.sh"

}


doctor() {

    local ERRORS=0

    echo
    echo "Inotify Security Monitor Doctor"
    echo
    
    show_version
    echo
    echo "System:"

    if command -v bash >/dev/null; then
        echo "  ✓ Bash available"
    else
        echo "  ✗ Bash missing"
        ERRORS=$((ERRORS+1))
    fi


    echo
    echo "Dependencies:"


    if command -v inotifywait >/dev/null; then
        echo "  ✓ inotify-tools installed"
    else
        echo "  ✗ inotify-tools missing"
        ERRORS=$((ERRORS+1))
    fi


    if command -v mail >/dev/null; then
        echo "  ✓ mail command available"
    else
        echo "  ⚠ mail command missing"
    fi



    echo
    echo "Service:"


    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo "  ✓ Service running"
    else
        echo "  ✗ Service stopped"
        ERRORS=$((ERRORS+1))
    fi



    echo
    echo "Configuration:"


    CONFIG_FILE="$PROJECT_ROOT/config/inotify-security-monitor.conf"


    if [ -f "$CONFIG_FILE" ]; then

        echo "  ✓ Configuration file found"

    else

        echo "  ✗ Configuration missing"
        ERRORS=$((ERRORS+1))

    fi



    echo
    echo "Monitoring:"


    if [ -f "$CONFIG_FILE" ]; then

        WATCH_DIR=$(awk '
        /^WATCH_DIRS=/ {flag=1; next}
        /^\)/ {flag=0}
        flag && /"/ {
            gsub(/"/,"")
            print $1
            exit
        }' "$CONFIG_FILE")


        if [ -d "$WATCH_DIR" ]; then

            echo "  ✓ Watch directory accessible"

        else

            echo "  ✗ Missing:"
            echo "    $WATCH_DIR"
            ERRORS=$((ERRORS+1))

        fi

    fi



    echo
    echo "Resources:"


    DISK=$(df "$PROJECT_ROOT" | awk 'NR==2 {print $5}' | tr -d '%')


    if [ "$DISK" -lt 90 ]; then

        echo "  ✓ Disk space OK ($DISK%)"

    else

        echo "  ⚠ Disk usage high ($DISK%)"

    fi

echo
echo "Logs:"

if [ -d "$PROJECT_ROOT/logs" ]; then
    echo "  ✓ Log directory exists"
else
    echo "  ✗ Log directory missing"
    ERRORS=$((ERRORS+1))
fi

    echo

    if [ "$ERRORS" -eq 0 ]; then

        echo "Result:"
        echo "  HEALTHY"

    else

        echo "Result:"
        echo "  ERRORS FOUND: $ERRORS"

        return 1

    fi

}


usage() {

cat <<EOF

Usage:

  ./ismctl <command>


Commands:

  version        Show installed version
  status         Show service status
  check-config   Validate configuration
  test-filter    Test filtering rules
  doctor         Run system health check

EOF

}


case "$1" in

    version)
        show_version
        ;;

    status)
        show_status
        ;;

    check-config)
        check_config
        ;;

    test-filter)
        test_filter
        ;;

    doctor)
        doctor
        ;;

    *)
        usage
        exit 1
        ;;

esac
